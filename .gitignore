# =============================================================================
# Go CLI Tool .gitignore - Comprehensive 2026 Edition
# =============================================================================
# Generated for: Anchor CLI Tool
# Last Updated: 2026-02-11
# Based on Go 1.25+ best practices

# =============================================================================
# 1. PRIMARY BINARY ARTIFACTS
# =============================================================================
# Your main CLI binary
anchor
anchor.exe

# Cross-platform binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Binary output directories
bin/
build/
dist/

# =============================================================================
# 2. GO TESTING & PROFILING
# =============================================================================
# Test binaries
*.test

# Coverage reports
coverage.*
*.coverprofile
profile.cov
coverage.html
coverage/

# Profiling data
*.prof
*.pprof
cpu.prof
mem.prof
block.prof
mutex.prof
trace.out

# Benchmark and test output
*.bench
*.out
race.log
vet.out

# =============================================================================
# 3. GO MODULES & CACHE (2025-2026)
# =============================================================================
# Go workspaces
go.work
go.work.sum

# Module files
go.sum.backup

# Build cache (if project-local)
.cache/
build-cache/

# Dependency management (uncomment if using vendor)
# vendor/

# =============================================================================
# 4. DEVELOPMENT TOOLS
# =============================================================================
# Hot reload (Air)
.air.toml
tmp/
tmpbuilder/

# Mock generation
mocks/
*_mock.go

# =============================================================================
# 5. IDE & EDITOR FILES
# =============================================================================
# JetBrains (GoLand)
.idea/
*.iml
*.ipr
*.iws

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Vim/Neovim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# 6. OPERATING SYSTEM FILES
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.com.apple.timemachine.supported
.desktop.ini

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# 7. ENVIRONMENT & CONFIGURATION
# =============================================================================
# Environment files (NEVER commit secrets)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# Your tool's specific storage file
.anchor_store.json

# =============================================================================
# 8. LOGS & RUNTIME DATA
# =============================================================================
# Log files
*.log
logs/
log/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# =============================================================================
# 9. FRONTEND & WEB COMPONENTS (if applicable)
# =============================================================================
# Node.js (for web interfaces)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build artifacts
public/build/
public/dist/
assets/build/

# =============================================================================
# 10. GENERATED FILES
# =============================================================================
# Generated code
*_generated.go
*_gen.go
generated/

# Tool-specific files
.golangci.yml
.golangci.yaml
staticcheck.conf

# Temporary files
*.tmp
*.temp
*.bak